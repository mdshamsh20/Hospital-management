generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id           Int       @id @default(autoincrement())
  patientId    Int?
  name         String?   
  email        String?
  phone        String?
  date         DateTime? @db.Date
  departmentId Int?
  doctorId     Int?
  message      String?
  status       String    @default("Registered") // Registered, Waiting, With Doctor, Procedure, Completed, Billing, Closed
  visitType    String    @default("Consultation") // Consultation, Follow-up, Procedure
  priority     String    @default("Normal")       // Normal, Urgent
  referredBy   String?
  token        Int?
  paymentStatus String   @default("Pending") // Pending, Paid
  serviceCharge Float?
  handledBy    String?   
  notes        String?
  estimatedWait Int?     // in minutes
  isWalkIn     Boolean   @default(true)
  arrivedAt    DateTime  @default(now())
  startedAt    DateTime? 
  completedAt  DateTime? 
  patient      Patient?  @relation(fields: [patientId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  doctor       Doctor?     @relation(fields: [doctorId], references: [id])
  diagnosticOrders DiagnosticOrder[]
  
  @@index([date])
  @@index([patientId])
  @@index([status])
}

model Patient {
  id            Int           @id @default(autoincrement())
  name          String
  age           Int?
  gender        String?
  phone         String?       @unique
  address       String?
  appointments  Appointment[]
  diagnosticOrders DiagnosticOrder[]
  medicalReports   MedicalReport[]
  treatmentPlans   DentalTreatmentPlan[]
  createdAt     DateTime      @default(now())
}

model Doctor {
  id           Int     @id @default(autoincrement())
  name         String?
  specialization String?
  onDuty       Boolean @default(true)
  availability String  @default("Available") // Available, Busy, On Break
  appointments Appointment[]
}

model Department {
  id   Int     @id @default(autoincrement())
  name String?
  appointments Appointment[]
}

model Inquiry {
  id      Int      @id @default(autoincrement())
  name    String?
  email   String?
  phone   String?
  subject String?
  message String?
  status  Boolean?
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  DOCTOR
}

model Users {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  password String?
  role     Role    @default(RECEPTIONIST)
}

model Staff {
  id          Int      @id @default(autoincrement())
  name        String
  role        String   @default("Staff") 
  contact     String?
  salary      Float?
  joiningDate DateTime @default(now())
  attendance  Attendance[]
  salaries    SalaryPayment[]
}

model Attendance {
  id           Int      @id @default(autoincrement())
  staffId      Int
  date         DateTime @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Float?
  status       String   @default("Present") 
  staff        Staff    @relation(fields: [staffId], references: [id])
}

model DentalLabOrder {
  id             Int       @id @default(autoincrement())
  patientName    String
  treatmentType  String    
  labName        String?   // New field
  caseType       String?   // Crown, Denture, Implant
  trialCount     Int       @default(1)
  impressionDate DateTime  @default(now())
  sentToLabDate  DateTime?
  expectedReturn DateTime?
  actualReturn   DateTime?
  status         String    @default("Impression Taken") // Impression Taken, Sent to Lab, In Fabrication, Ready for Fit, Fitting Scheduled, Completed
  isDelayed      Boolean   @default(false)
  cost           Float?
  notes          String?
  followUpDate   DateTime?
  receptionAction String    @default("Pending")
  createdAt      DateTime  @default(now())
}

model SalaryPayment {
  id      Int      @id @default(autoincrement())
  staffId Int
  month   String
  amount  Float
  date    DateTime @default(now())
  staff   Staff    @relation(fields: [staffId], references: [id])
}

model InventoryItem {
  id           Int      @id @default(autoincrement())
  name         String
  category     String?
  stock        Int      @default(0)
  unit         String?
  vendorName   String?  // New field
  expiryDate   DateTime? // New field
  purchases    PurchaseRecord[]
  consumptions MaterialConsumption[]
}

model PurchaseRecord {
  id       Int      @id @default(autoincrement())
  itemId   Int
  quantity Int
  cost     Float
  date     DateTime @default(now())
  item     InventoryItem @relation(fields: [itemId], references: [id])
}

model MaterialConsumption {
  id          Int      @id @default(autoincrement())
  itemId      Int
  quantity    Int
  usedFor     String?  
  date        DateTime @default(now())
  item        InventoryItem @relation(fields: [itemId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  category    String   
  description String?
  amount      Float
  date        DateTime @default(now())

  @@index([date])
}

model DiagnosticOrder {
  id             Int           @id @default(autoincrement())
  patientId      Int
  appointmentId  Int?
  type           String        // X-Ray, Ultrasound
  testName       String?       
  status         String        @default("Pending") // Pending, In Progress, Completed, Cancelled
  priority       String        @default("Normal")
  technicianName String?
  notes          String?       
  cost           Float         @default(0)
  createdAt      DateTime      @default(now())
  report         MedicalReport?
  patient        Patient       @relation(fields: [patientId], references: [id])
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model MedicalReport {
  id              Int             @id @default(autoincrement())
  orderId         Int?            @unique
  patientId       Int
  serviceType     String          // Dental, X-Ray, Ultrasound, Consultation
  findings        String?
  impression      String?
  recommendations String?
  images          String[]        
  status          String          @default("Draft") // Draft, Under Review, Final, Delivered
  pdfUrl          String?
  finalizedAt     DateTime?
  finalizedBy     String?
  createdAt       DateTime        @default(now())
  order           DiagnosticOrder? @relation(fields: [orderId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])

  @@index([createdAt])
  @@index([status])
}

model DentalTreatmentPlan {
  id             Int             @id @default(autoincrement())
  patientId      Int
  patientName    String
  primaryConcern String?
  totalStages    Int             @default(1)
  status         String          @default("Active") // Active, Completed, Dropped
  createdAt      DateTime        @default(now())
  sittings       DentalSitting[]
  patient        Patient         @relation(fields: [patientId], references: [id])
}

model DentalSitting {
  id              Int                 @id @default(autoincrement())
  planId          Int
  sittingNumber   Int
  procedureDone   String?
  toothNumber     String?
  materialUsed    String?
  notes           String?
  status          String              @default("Pending") // Pending, Completed
  date            DateTime            @default(now())
  treatmentPlan   DentalTreatmentPlan @relation(fields: [planId], references: [id])
}

model SampleCollection {
  id              Int      @id @default(autoincrement())
  patientName     String
  sampleType      String
  sampleId        String   @unique
  collectionDate  DateTime @default(now())
  externalLab     String?
  collectedBy     String?
  amountCollected Float    @default(0)
  labPayment      Float    @default(0)
  margin          Float    @default(0)
  status          String   @default("Collected") // Collected, Sent to Lab, Partner Received, Result Uploaded
  paymentStatus   String   @default("Pending")   // Pending, Paid, Mismatched
  notes           String?

  @@index([collectionDate])
  @@index([status])
}

model CommissionRecord {
  id            Int      @id @default(autoincrement())
  appointmentId Int?     @unique
  doctorName    String   // Referring or Consultant
  patientName   String
  totalBilling  Float
  commissionAmount Float
  percentage    Float
  type          String   // Referral, Consultation
  status        String   @default("Pending") // Pending, Approved, Paid
  month         String   // e.g., "February 2026"
  createdAt     DateTime @default(now())
  approvedAt    DateTime?
}

model ClinicSettings {
  id              Int      @id @default(1)
  clinicName      String   @default("Radiance Clinic")
  startTime       String   @default("09:00")
  endTime         String   @default("21:00")
  tokenResetRule  String   @default("Daily")
  defaultXrayFee  Float    @default(500)
  defaultUsgFee   Float    @default(1200)
  referralComm    Float    @default(10) // Default 10%
  doctorComm      Float    @default(60) // Default 60%
  labTurnaround   Int      @default(3)
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  module    String
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}

model DentalCase {
  id          Int      @id @default(autoincrement())
  patientName String
  type        String   
  status      String   @default("Scheduled")
  date        DateTime @default(now())
}
